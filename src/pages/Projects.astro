---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { projects } from '../Data/projects';

const sorted = [...projects].sort((a, b) => b.updated.getTime() - a.updated.getTime());
---

<!doctype html>
<html lang="en">
<head>
    <BaseHead title="Projects — Alfie Ralls" description="Things I'm building" />
</head>

<body>
<Header />
<main>
    <div>
        <h1>Projects</h1>
        <div class="intro-box">
            Most of what I do is open source (where possible). Find my code on <a href="https://github.com/Alfie-sci" target="_blank">Github</a>
        </div>
    </div>

    <div class="projects-grid">
        {sorted.map((project) => (
                <article class="project-card">
                    <div class="card-header">
                        <span class="tag">{project.tag}</span>
                        <span class={
                            project.status === 'active' ? 'active-status' :
                                project.status === 'planned' ? 'planned-status' :
                                    'inactive-status'
                        }>● {project.status}</span>
                    </div>
                    <h2>{project.title}</h2>
                    <p>{project.summary}</p>
                    <div class="card-footer">
                        <span class="tech">{project.tech}</span>
                        <span class="updated">Updated {project.updated.toLocaleDateString('en-GB', { month: 'short', year: 'numeric' })}</span>
                    </div>
                </article>
        ))}
    </div>

</main>
<Footer />
</body>
</html>
