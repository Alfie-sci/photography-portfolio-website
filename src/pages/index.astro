---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Hi, I'm Alfie Ralls</h1>
			<h5>
				Computer science student and photographer
			</h5>
			<div class="intro-box">
				<p>
					I am a Computer Science student at
					<a href="https://www.lancaster.ac.uk" target="_blank" rel="noopener">Lancaster University</a>,
					with a strong interest in software engineering and the broader landscape of computing.
					Alongside my academic work, I am an active photographer, with a particular focus on UK railways,
					a subject that frequently appears in my work.
				</p>
			</div>
		</main>
		<Footer />
	</body>
</html>
