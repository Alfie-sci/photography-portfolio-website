---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
<head>
	<BaseHead title="Alfie Ralls" description="My portfolio website" />
</head>
		<body>
			<Header />
			<main>
				<h1>Alfie</h1>
				<div class="terminal-box">
					<div class="terminal-bar">
						<span class="terminal-dot red"></span>
						<span class="terminal-dot yellow"></span>
						<span class="terminal-dot green"></span>
						<span class="terminal-title">alfie@portfolio ~ </span>
					</div>
					<div class="terminal-body">
						<p class="terminal-line" id="line1"></p>
						<p class="terminal-line" id="line2"></p>
						<p class="terminal-line" id="line3"></p>
						<p class="terminal-line" id="line4"></p>
						<p class="terminal-line" id="line5"></p>
						<p class="terminal-line" id="line6"></p>
						<p class="terminal-line" id="line7"></p>
						<p class="terminal-line" id="line8"></p>
					</div>
				</div>
			</main>
		<Footer />
		</body>
</html>

<script>
	const lines = [
		{ prompt: "$ ", text: "whoami", type: "command" },
		{ text: "Alfie Ralls — CS student, photographer, Wikipedia contributor", type: "output" },
		{ prompt: "$ ", text: "ls interests/", type: "command" },
		{ text: "railways/linux/open-source/cameras/cybersecurity", type: "output" },
		{ prompt: "$ ", text: "ls design/", type: "output" },
		{ text: "This site is inspired by the design principles outlined in www.nordtheme.com."},
		{ prompt: "$ ", text: "logout", type: "output" },
		{ text: "Thank you for visiting my website :)", type: "output" },
	];

	const delays = [500, 1200, 2200, 2900, 3500, 4000, 4500, 5000];

	function typeText(el: Element, text: string, speed: number): Promise<void> {
		return new Promise((resolve) => {
			let i = 0;
			const interval = setInterval(() => {
				el.textContent += text[i];
				i++;
				if (i >= text.length) {
					clearInterval(interval);
					resolve();
				}
			}, speed);
		});
	}

	async function runTerminal() {
		for (let i = 0; i < lines.length; i++) {
			const line = lines[i];
			await new Promise(r => setTimeout(r, i === 0 ? delays[0] : delays[i] - delays[i - 1]));

			const el = document.getElementById(`line${i + 1}`);
			if (!el) continue;

			if (line.type === 'command') {
				el.innerHTML = `<span class="prompt">${line.prompt}</span>`;
				await typeText(el, line.text, 50);
			} else {
				el.innerHTML = `<span class="output"></span>`;
				await typeText(el.querySelector('.output')!, line.text, 25);
			}
		}

		// All lines done — append cursor
		const body = document.querySelector('.terminal-body');
		if (body) {
			const cursor = document.createElement('span');
			cursor.className = 'cursor';
			cursor.textContent = '▋';
			body.appendChild(cursor);
		}
	}

	runTerminal();
</script>