---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<img src="/portrait.jpg" alt="Portrait" class="profile-pic" />
			<h1>Alfie Ralls</h1>
			<h6>
				<code> Computer science student and photographer </code>
			</h6>
			<div class="intro-box">
				<p>
					Hello, I am a first year computer science student at
					<a href="https://www.lancaster.ac.uk" target="_blank" rel="noopener"> Lancaster University</a>.
					passionate about software engineering, anything computer science, photography,
					and UK railways (a theme you will see featured heavily in my photography), the world, and anything
					geopolitics interests me greatly.
				</p>
			</div>
		</main>
		<Footer />
	</body>
</html>
