---
import HeaderLink from './HeaderLink.astro';
import { SITE_TITLE } from '../consts';
---

<header>
    <nav class="pill-nav">
        <HeaderLink href="/">Home</HeaderLink>
        <HeaderLink href="/About">About</HeaderLink>
        <HeaderLink href="/Photos">Photos</HeaderLink>
    </nav>
</header>
<style>
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
    header {
        display: flex;
        justify-content: center;
        margin-top: 0.5rem;
        margin-bottom: 0.5rem;
    }

    .pill-nav {
        display: flex;
        background: var(--bg-light);
        border-radius: 999px;
        backdrop-filter: blur(4px);
    }

    .pill-nav a {
        padding: 0.6rem 1.2rem;
        border-radius: 999px;
        text-decoration: none;
        color: var(--text-soft);
        transition: background 0s ease, color 0s ease;
    }

    .pill-nav a:hover {
        background: rgba(129, 161, 193, 0.15);
        color: var(--text);
    }

    .pill-nav a.active {
        background: var(--accent);
        color: var(--text);
    }
	.social-links,
	.social-links a {
		display: flex;
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
</style>
